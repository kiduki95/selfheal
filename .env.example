# Copy to .env and adjust. The pipeline runs fully without any API keys (stub clients).

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgres://ouroboros:ouroboros@localhost:5433/ouroboros

# --- LLM client selection ---
# stub       = deterministic rule-based responses, no key, no cost (default)
# claude-cli = real Claude via your logged-in SUBSCRIPTION (local `claude -p` headless).
#              No API key, no metered top-up — consumes subscription usage. Dev-recommended.
# anthropic  = metered Anthropic API (requires ANTHROPIC_API_KEY, pay-per-token)
LLM_CLIENT=stub
# CLAUDE_BIN=claude.exe        # override path to the claude CLI if not on PATH
# ANTHROPIC_API_KEY=sk-ant-...

# --- Embedding client selection ---
# local  = deterministic hashed char-ngram embedding, no key (default)
# cohere = Cohere embed-multilingual-v3 (requires COHERE_API_KEY)
EMBEDDING_CLIENT=local
# COHERE_API_KEY=...
